{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "NotebookEdit",
      "WebSearch",
      "WebFetch",
      "Bash(python:*)",
      "Bash(py:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(ls:*)",
      "Bash(dir:*)",
      "Bash(pwd:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(echo:*)",
      "Bash(where:*)",
      "Bash(which:*)"
    ],
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git checkout --:*)",
      "Bash(git restore:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(del /s:*)",
      "Bash(rmdir /s:*)",
      "Bash(format:*)",
      "Bash(shutdown:*)",
      "Bash(diskpart:*)"
    ]
  }
}
